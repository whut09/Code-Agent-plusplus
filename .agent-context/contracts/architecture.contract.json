{
  "schemaVersion": 1,
  "kind": "architecture-contract",
  "purpose": "Constrain coding agents to preserve the detected repository architecture and dependency shape.",
  "languages": [
    "JSON",
    "JavaScript",
    "Markdown",
    "Python",
    "TOML",
    "TypeScript",
    "YAML"
  ],
  "frameworks": [],
  "packageManagers": [
    "npm"
  ],
  "entrypoints": [
    "src/cli/index.ts",
    "src/mcp/server.ts"
  ],
  "layers": [
    {
      "name": "core",
      "owns": [
        "src/core/**"
      ],
      "allowedImports": [
        "src/core/**",
        "src/config/**"
      ],
      "forbiddenImports": [
        "src/outputs/**",
        "src/cli/**",
        "test/**",
        "benchmarks/**"
      ],
      "rule": "architecture.contract.json#layers.core"
    },
    {
      "name": "config",
      "owns": [
        "src/config/**"
      ],
      "allowedImports": [
        "src/core/**",
        "src/config/**"
      ],
      "forbiddenImports": [
        "src/outputs/**",
        "src/cli/**",
        "test/**",
        "benchmarks/**"
      ],
      "rule": "architecture.contract.json#layers.config"
    },
    {
      "name": "outputs",
      "owns": [
        "src/outputs/**"
      ],
      "allowedImports": [
        "src/core/**",
        "src/config/**",
        "src/outputs/**",
        "src/retrievers/**"
      ],
      "forbiddenImports": [
        "src/cli/**",
        "test/**",
        "benchmarks/**"
      ],
      "rule": "architecture.contract.json#layers.outputs"
    },
    {
      "name": "retrievers",
      "owns": [
        "src/retrievers/**"
      ],
      "allowedImports": [
        "src/core/**",
        "src/config/**",
        "src/retrievers/**"
      ],
      "forbiddenImports": [
        "src/cli/**",
        "test/**",
        "benchmarks/**"
      ],
      "rule": "architecture.contract.json#layers.retrievers"
    },
    {
      "name": "cli",
      "owns": [
        "src/cli/**"
      ],
      "allowedImports": [
        "src/**"
      ],
      "forbiddenImports": [
        "test/**",
        "benchmarks/**"
      ],
      "rule": "architecture.contract.json#layers.cli"
    }
  ],
  "modules": [
    {
      "name": "benchmarks",
      "owns": [
        "benchmarks/**"
      ],
      "imports": [
        "core",
        "outputs"
      ],
      "summary": "benchmarks contains 50 files and depends on core, outputs."
    },
    {
      "name": "test",
      "owns": [
        "test/**"
      ],
      "imports": [
        "analyzers",
        "benchmarks",
        "cli",
        "config",
        "core",
        "mcp",
        "outputs",
        "retrievers"
      ],
      "summary": "test contains 33 files and depends on analyzers, benchmarks, cli, config, core, mcp, outputs, retrievers."
    },
    {
      "name": "outputs",
      "owns": [
        "src/outputs/**"
      ],
      "imports": [
        "core"
      ],
      "summary": "outputs contains 20 files and depends on core."
    },
    {
      "name": "core",
      "owns": [
        "src/core/**"
      ],
      "imports": [
        "analyzers",
        "config",
        "llm"
      ],
      "summary": "core contains 15 files and depends on analyzers, config, llm."
    },
    {
      "name": "retrievers",
      "owns": [
        "src/retrievers/**"
      ],
      "imports": [
        "core",
        "outputs"
      ],
      "summary": "retrievers contains 6 files and depends on core, outputs."
    },
    {
      "name": "analyzers",
      "owns": [
        "src/analyzers/**"
      ],
      "imports": [
        "core"
      ],
      "summary": "analyzers contains 6 files and depends on core."
    },
    {
      "name": "cli",
      "owns": [
        "src/cli/**"
      ],
      "imports": [
        "benchmarks",
        "config",
        "core",
        "outputs",
        "retrievers"
      ],
      "summary": "cli contains 2 files and depends on benchmarks, config, core, outputs, retrievers."
    },
    {
      "name": "config",
      "owns": [
        "src/config/**"
      ],
      "imports": [
        "core"
      ],
      "summary": "config contains 3 files and depends on core."
    },
    {
      "name": "mcp",
      "owns": [
        "src/mcp/**"
      ],
      "imports": [
        "core",
        "outputs",
        "retrievers"
      ],
      "summary": "mcp contains 1 file and depends on core, outputs, retrievers."
    },
    {
      "name": "root",
      "owns": [
        "*"
      ],
      "imports": [],
      "summary": "root contains 17 files."
    },
    {
      "name": "llm",
      "owns": [
        "src/llm/**"
      ],
      "imports": [
        "core"
      ],
      "summary": "llm contains 1 file and depends on core."
    },
    {
      "name": "docs",
      "owns": [
        "docs/**"
      ],
      "imports": [],
      "summary": "docs contains 4 files."
    },
    {
      "name": ".github",
      "owns": [
        ".github/**"
      ],
      "imports": [],
      "summary": ".github contains 1 file."
    },
    {
      "name": "assets",
      "owns": [
        "assets/**"
      ],
      "imports": [],
      "summary": "assets contains 4 files."
    }
  ],
  "rules": [
    "Preserve detected entrypoints unless the task explicitly changes application wiring.",
    "Prefer extending existing modules over creating new top-level architecture.",
    "Preserve layer direction rules in layers[].forbiddenImports.",
    "Do not add cross-module dependencies that are absent from module-boundaries.json without task-specific justification.",
    "Run commands from commands.contract.json after source or configuration edits."
  ]
}
